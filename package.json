{
    "name": "quack-table",
    "displayName": "QuackTable - Structured Data Explorer",
    "description": "Visual explorer for Parquet, CSV, and JSON files with powerful SQL querying, schema inspection, and data statistics powered by DuckDB",
    "version": "1.1.4",
    "publisher": "arunpandian7",
    "author": "Arun Pandian R <arunpandian.srk@gmail.com>",
    "icon": "icon.png",
    "private": true,
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/arun/quack-table"
    },
    "engines": {
        "vscode": "^1.95.0"
    },
    "categories": [
        "Data Science",
        "Visualization",
        "Other"
    ],
    "activationEvents": [
        "onCustomEditor:quackTable.dataExplorer",
        "onChatParticipant:quacktable"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "chatParticipants": [
            {
                "id": "quacktable",
                "name": "quacktable",
                "fullName": "QuackTable",
                "description": "Ask questions about your data file, get SQL suggestions, explanations and fixes — powered by your schema and current query.",
                "isSticky": true,
                "commands": [
                    {
                        "name": "suggest",
                        "description": "Suggest 5 useful queries for this dataset"
                    },
                    {
                        "name": "explain",
                        "description": "Explain what the current query does"
                    },
                    {
                        "name": "fix",
                        "description": "Fix or improve the current query"
                    }
                ]
            }
        ],
        "customEditors": [
            {
                "viewType": "quackTable.dataExplorer",
                "displayName": "QuackTable",
                "selector": [
                    { "filenamePattern": "*.parquet" },
                    { "filenamePattern": "*.parq" },
                    { "filenamePattern": "*.pq" },
                    { "filenamePattern": "*.csv" },
                    { "filenamePattern": "*.tsv" },
                    { "filenamePattern": "*.csv.gz" },
                    { "filenamePattern": "*.tsv.gz" },
                    { "filenamePattern": "*.json" },
                    { "filenamePattern": "*.jsonl" }
                ],
                "priority": "default"
            }
        ],
        "configuration": {
            "title": "QuackTable",
            "properties": {
                "quack-table.chunkSize": {
                    "type": "integer",
                    "default": 500,
                    "minimum": 50,
                    "markdownDescription": "Number of rows fetched per request when paginating results."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./",
        "lint": "eslint \"src/**/*.ts\""
    },
    "devDependencies": {
        "@types/node": "^20.17.10",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^8.18.1",
        "@typescript-eslint/parser": "^8.18.1",
        "@vscode/vsce": "^3.7.1",
        "typescript": "^5.7.2"
    },
    "dependencies": {
        "duckdb": "^1.4.3",
        "monaco-editor": "^0.52.0"
    }
}
